# Copy this file to .env locally (on Render, set these as Environment Variables
# in the dashboard instead — never commit a real .env file).

# Get a free key at https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Any current chat model from https://console.groq.com/docs/models
LLM_MODEL_NAME=llama-3.3-70b-versatile

# Local embedding model (downloaded once, runs on CPU)
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2

# Retrieval tuning
CHUNK_SIZE=800
CHUNK_OVERLAP=150
RETRIEVAL_K=3

# Where uploaded PDFs and the FAISS index are stored (relative to backend/)
UPLOAD_DIR=app/data/uploads
FAISS_INDEX_DIR=app/data/faiss_index

# Comma-separated list of origins allowed to call this API.
# Only needed if you serve the frontend as a SEPARATE origin from the API
# (e.g. a separate Render Static Site). If the frontend is served by this
# same FastAPI app (the default setup below), you can leave this as-is.
ALLOWED_ORIGINS=http://localhost:5500,http://127.0.0.1:5500,http://localhost:3000

# -- Auth --
# REQUIRED in production. Generate one with:
#   python -c "import secrets; print(secrets.token_hex(32))"
# Anyone who has this value can forge login tokens, so keep it secret and
# never commit a real one.
JWT_SECRET_KEY=change-this-to-a-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# -- Database (stores user accounts only; documents stay on disk per-user) --
DATABASE_URL=sqlite:///./app/data/app.db
